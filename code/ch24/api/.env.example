# 文件：code/ch24/api/.env.example
# 这是一个「模板」，可以安全地提交到 git，告诉别人需要哪些环境变量。
# 真正的 .env（可能含密钥）绝不入库——见 .gitignore。
# 用法：复制一份为 .env 再按需修改：  cp .env.example .env

# HTTP 监听端口（1~65535），不填默认 3000
PORT=3000

# SQLite 数据库文件路径（相对路径会相对于运行目录解析），不填默认 data/tasks.db
DB_FILE=data/tasks.db

# 运行环境：development / production / test
NODE_ENV=development
